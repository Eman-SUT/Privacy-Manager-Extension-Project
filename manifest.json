{
  "manifest_version": 3,
  "name": "Privacy Manager",
  "version": "1.0",
  "description": "Trackers & Privacy Manager",

  "permissions": [
    "storage",
    "tabs",
    "cookies",
    "scripting",
    "activeTab",
    "declarativeNetRequest"
  ],

  "host_permissions": [
    "http://127.0.0.1:5000/*",
    "<all_urls>"
  ],

  "action": {
    "default_popup": "popup.html"
  },

  "background": {
    "service_worker": "background.js"
  },

  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_1",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  }
}
